{
  "manifest_version": 2,
  "name": "Blazor Developer Tools",
  "version": "1.0.0.2",
  "description": "Developer tools for debugging Blazor applications",
  
  "devtools_page": "devtools.html",
  
  "permissions": [
    "<all_urls>",
    "tabs"
  ],
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  
  "background": {
    "scripts": ["background.js"]
  },
  
  "web_accessible_resources": [
    "bridge.js"
  ],
  
  "browser_action": {
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png"
    },
    "default_title": "Blazor Developer Tools"
  },
  
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  
  "browser_specific_settings": {
    "gecko": {
      "id": "blazor-devtools@example.com",
      "strict_min_version": "109.0"
    }
  }
}
